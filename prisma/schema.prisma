datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// ---------------------------------------------------------------------------
// Pessoas / acesso
// ---------------------------------------------------------------------------

model Client {
  id           Int      @id @default(autoincrement())
  docNumber    String   @unique @map("doc_number") // CPF ou CNPJ, usado como login
  name         String
  phone        String
  email        String?
  passwordHash String   @map("password_hash")

  // Bloqueio temporário após tentativas de login inválidas seguidas
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  services          Service[]
  payments          Payment[]
  sessions          Session[]
  pushSubscriptions PushSubscription[]
  loginEvents       ClientLoginEvent[]

  @@map("clients")
}

// Histórico de acessos do cliente, mostrado no admin (ficha do cliente).
// Diferente de Session (que é apagada quando expira — só serve pra
// autenticação em si), essa tabela nunca é limpa: é o registro histórico
// de "quando esse cliente entrou", não uma credencial ativa.
model ClientLoginEvent {
  id        Int      @id @default(autoincrement())
  clientId  Int      @map("client_id")
  createdAt DateTime @default(now()) @map("created_at")
  ipAddress String?  @map("ip_address")

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@map("client_login_events")
}

// Uma linha por dispositivo/navegador inscrito em push (um cliente pode ter
// várias — celular e PC, por exemplo). endpoint já é o identificador único
// de verdade (a própria API PushManager garante isso); p256dh/auth são as
// chaves de criptografia que o web-push precisa pra cifrar o payload.
model PushSubscription {
  id        Int      @id @default(autoincrement())
  clientId  Int      @map("client_id")
  endpoint  String   @unique @db.VarChar(500)
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@map("push_subscriptions")
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  name         String
  passwordHash String   @map("password_hash")

  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")

  createdAt DateTime @default(now()) @map("created_at")

  reviewedPayments Payment[]  @relation("PaymentReviewedBy")
  auditLogs        AuditLog[]
  sessions         Session[]

  @@map("admins")
}

// Sessão de login. Guardamos só o hash do token (nunca o token em si),
// igual senha, pra um vazamento do banco não virar sequestro de sessão
// direto. O cookie guarda o token em texto puro; o servidor compara o hash.
model Session {
  id        Int       @id @default(autoincrement())
  tokenHash String    @unique @map("token_hash")
  actorType ActorType @map("actor_type")

  clientId Int? @map("client_id")
  adminId  Int? @map("admin_id")

  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  client Client? @relation(fields: [clientId], references: [id])
  admin  Admin?  @relation(fields: [adminId], references: [id])

  @@index([clientId])
  @@index([adminId])
  @@index([expiresAt])
  @@map("sessions")
}

// Dados do Evaldo mostrados ao cliente na hora de pagar (chave PIX, WhatsApp).
// Fica em tabela em vez de hardcoded no front, para poder editar via admin.
model BusinessProfile {
  id            Int      @id @default(autoincrement())
  businessName  String   @map("business_name")
  pixKey        String   @map("pix_key")
  whatsappPhone String   @map("whatsapp_phone")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("business_profile")
}

// ---------------------------------------------------------------------------
// Serviços e pagamentos
// ---------------------------------------------------------------------------

model Service {
  id          Int      @id @default(autoincrement())
  clientId    Int      @map("client_id")
  description String
  totalAmount Decimal  @map("total_amount") @db.Decimal(10, 2)
  serviceDate DateTime @map("service_date") @db.Date
  dueDate     DateTime? @map("due_date") @db.Date
  createdAt   DateTime @default(now()) @map("created_at")

  // Marca quando cada lembrete de push já foi mandado, pra não avisar duas
  // vezes o mesmo vencimento (o cron roda 1x/dia, mas se o serviço ainda
  // bater no mesmo critério no dia seguinte por algum motivo, não reenviar).
  notifiedThreeDaysAt DateTime? @map("notified_three_days_at")
  notifiedDueDateAt   DateTime? @map("notified_due_date_at")

  client   Client    @relation(fields: [clientId], references: [id])
  payments Payment[]

  @@index([clientId])
  @@map("services")
}

enum PaymentMethod {
  PIX
  DINHEIRO
}

enum PaymentStatus {
  AGUARDANDO_VALIDACAO
  APROVADO
  REJEITADO
}

model Payment {
  id         Int           @id @default(autoincrement())
  serviceId  Int           @map("service_id")
  clientId   Int           @map("client_id") // denormalizado: toda query de isolamento por cliente filtra direto aqui, sem join
  amount     Decimal       @db.Decimal(10, 2)
  method     PaymentMethod
  status     PaymentStatus @default(AGUARDANDO_VALIDACAO)
  createdAt  DateTime      @default(now()) @map("created_at")

  reviewedByAdminId Int?      @map("reviewed_by_admin_id")
  reviewedAt        DateTime? @map("reviewed_at")
  rejectionReason   String?   @map("rejection_reason")

  service         Service          @relation(fields: [serviceId], references: [id])
  client          Client           @relation(fields: [clientId], references: [id])
  reviewedByAdmin Admin?           @relation("PaymentReviewedBy", fields: [reviewedByAdminId], references: [id])
  proof           PaymentProof?
  auditLogs       AuditLog[]

  @@index([serviceId])
  @@index([clientId])
  @@index([status])
  @@map("payments")
}

model PaymentProof {
  id               Int      @id @default(autoincrement())
  paymentId        Int      @unique @map("payment_id")
  filePath         String   @map("file_path")
  originalFileName String   @map("original_file_name")
  mimeType         String   @map("mime_type")
  fileSizeBytes    Int      @map("file_size_bytes")
  uploadedAt       DateTime @default(now()) @map("uploaded_at")

  payment Payment @relation(fields: [paymentId], references: [id])

  @@map("payment_proofs")
}

// ---------------------------------------------------------------------------
// Auditoria
// ---------------------------------------------------------------------------

enum ActorType {
  CLIENT
  ADMIN
}

enum AuditAction {
  CRIADO
  APROVADO
  REJEITADO
  REENVIADO
}

model AuditLog {
  id            Int           @id @default(autoincrement())
  paymentId     Int           @map("payment_id")
  actorType     ActorType     @map("actor_type")
  actorAdminId  Int?          @map("actor_admin_id")
  action        AuditAction
  statusBefore  PaymentStatus? @map("status_before")
  statusAfter   PaymentStatus  @map("status_after")
  amountBefore  Decimal?      @db.Decimal(10, 2) @map("amount_before")
  amountAfter   Decimal       @db.Decimal(10, 2) @map("amount_after")
  createdAt     DateTime      @default(now()) @map("created_at")

  payment    Payment @relation(fields: [paymentId], references: [id])
  actorAdmin Admin?  @relation(fields: [actorAdminId], references: [id])

  @@index([paymentId])
  @@map("audit_logs")
}
